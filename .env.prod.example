# Production environment variables - Copy to .env.prod and configure with actual values
# Using external services: Supabase, Upstash Redis, Meilisearch Cloud, Cloudflare R2

# ===== DATABASE (SUPABASE) =====
# Available at Supabase Project Settings > Database > Connection String > URI
# Or use Connection Pooling with PgBouncer (recommended for serverless)
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# ===== REDIS CACHE (UPSTASH) =====
# Available at Upstash Console > Redis instance > REST API or CLI
# Format: redis://default:password@endpoint.upstash.io:port
REDIS_URL=redis://default:your-secure-password@your-endpoint.upstash.io:your-port

# ===== SEARCH ENGINE (MEILISEARCH CLOUD) =====
# Sign up at https://cloud.meilisearch.io/
# Get Host URL and Master Key from project dashboard
MEILISEARCH_HOST=https://your-instance-abc123.meilisearch.io
MEILISEARCH_API_KEY=your-master-key-min-16-characters
MEILISEARCH_PRODUCT_INDEX_NAME=products

# ===== FILE STORAGE (CLOUDFLARE R2) =====
# Get these from Cloudflare dashboard > R2 > API Tokens
# Create R2 API token with appropriate permissions
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_BUCKET=your-bucket-name
S3_REGION=auto
# Custom domain (optional): Set up a custom domain in R2 bucket settings
S3_FILE_URL=https://cdn.yourdomain.com

# ===== SECURITY SECRETS =====
# Generate strong random values for production
JWT_SECRET=your_very_secure_jwt_secret_here_min_32_characters_recommended_64
COOKIE_SECRET=your_very_secure_cookie_secret_here_min_32_characters_recommended_64

# ===== CORS CONFIGURATION =====
# Update with your production domain
STORE_CORS=https://yourdomain.com,https://www.yourdomain.com
ADMIN_CORS=https://yourdomain.com/admin
AUTH_CORS=https://yourdomain.com/admin

# ===== BACKEND URL =====
# URL where storefront will reach the backend
MEDUSA_BACKEND_URL=https://api.yourdomain.com

# ===== PAYMENT PROCESSING (STRIPE) =====
# Get from Stripe Dashboard > API Keys
STRIPE_API_KEY=sk_live_your_stripe_live_key_here
NEXT_PUBLIC_STRIPE_KEY=pk_live_your_stripe_live_public_key_here

# ===== MEDUSA SDK CONFIGURATION =====
# Get from Medusa settings
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_live_your_medusa_publishable_key_here

# ===== MEILISEARCH PUBLIC CONFIGURATION =====
# Public endpoint for storefront search
# Use your custom domain for better branding
NEXT_PUBLIC_MEILISEARCH_HOST=https://search.yourdomain.com
NEXT_PUBLIC_MEILISEARCH_API_KEY=your-master-key-min-16-characters
NEXT_PUBLIC_MEILISEARCH_INDEX_NAME=products

# ===== ERROR TRACKING (OPTIONAL) =====
# Sentry integration for error monitoring
SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id

# ===== DISABLE ADMIN (OPTIONAL) =====
# Set to "true" if you want to disable the built-in admin dashboard
DISABLE_MEDUSA_ADMIN=false
