# Docker environment file for development with external services
# Copy to .env and configure as needed for your environment

# ===== SUPABASE CONFIGURATION =====
# Get these from Supabase project settings
DATABASE_URL=postgresql://postgres:password@project-id.supabase.co:5432/postgres?sslmode=require

# ===== UPSTASH REDIS CONFIGURATION =====
# Get this from Upstash console - Redis connection URL
REDIS_URL=redis://default:password@endpoint.upstash.io:port

# ===== MEILISEARCH CLOUD CONFIGURATION =====
# Get these from Meilisearch Cloud dashboard
MEILISEARCH_HOST=https://your-instance.meilisearch.io
MEILISEARCH_API_KEY=your_meilisearch_api_key
MEILISEARCH_PRODUCT_INDEX_NAME=products

# ===== CLOUDFLARE R2 CONFIGURATION =====
# Get these from Cloudflare R2 account dashboard
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your_r2_access_key_id
S3_SECRET_ACCESS_KEY=your_r2_secret_access_key
S3_FILE_URL=https://your-custom-domain.com
S3_REGION=auto
S3_BUCKET=your-bucket-name

# ===== MEDUSA CONFIGURATION =====
STORE_CORS=http://localhost:8000,http://localhost:3000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000
JWT_SECRET=your-jwt-secret-min-32-characters
COOKIE_SECRET=your-cookie-secret-min-32-characters
MEDUSA_BACKEND_URL=http://localhost:9000

# ===== STRIPE CONFIGURATION =====
STRIPE_API_KEY=sk_test_your_stripe_key_here

# ===== OPTIONAL: MONITORING =====
SENTRY_DSN=

# ===== NEXT.js STOREFRONT CONFIGURATION =====
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_test_your_medusa_key
NEXT_PUBLIC_STRIPE_KEY=pk_test_your_stripe_key
NEXT_PUBLIC_MEILISEARCH_HOST=https://your-instance.meilisearch.io
NEXT_PUBLIC_MEILISEARCH_API_KEY=your_meilisearch_api_key
NEXT_PUBLIC_MEILISEARCH_INDEX_NAME=products
